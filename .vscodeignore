# What ships in the VSIX is the esbuild bundle in out/ plus the static contribution assets
# (images, syntaxes, l10n, media, language configuration) and package.json/README/LICENSE/CHANGELOG.
# Everything below is excluded because it is dev-only or already bundled.

# --- Editor / tooling / CI config ---
.vscode/**
.vscode-test/**
.idea/**
.claude/**
.github/**
.gitignore
.prettierignore
.prettierrc.json5
eslint.config.mjs
vitest.config.ts
esbuild.mjs
package-lock.json
CONTRIBUTING
SUPPORT.md
.travis.yml
**/tsconfig.json
**/tsconfig.base.json

# --- Sources and build metadata (the runtime is the esbuild bundle in out/) ---
**/*.ts
**/*.map
out/**/*.tsbuildinfo

# --- Tests, fixtures, snapshots ---
**/test/**
**/testFixture/**
**/__snapshots__/**
**/*.snap

# --- Repo tooling, docs, media and the JetBrains plugin (not part of the extension) ---
jetbrains/**
tools/**
docs/**
showcase/**
scripts/**

# --- Subpackage build outputs and manifests: bundled into out/, not loaded at runtime ---
client/out/**
client/package.json
client/package-lock.json
server/**

# --- node_modules: esbuild bundles every dependency (only 'vscode' is external), so the
#     packaged bundle requires nothing from node_modules at runtime. ---
node_modules/**
**/node_modules/**
