{
    "compilerOptions": {
        "target": "ES2024",
        "lib": ["ES2024"],
        "module": "Node16",
        "moduleResolution": "Node16",
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "../out/server",
        "rootDir": "src",
        "incremental": true,
        "esModuleInterop": true,
        "types": ["node"],
        "tsBuildInfoFile": "../out/server.tsbuildinfo"
    },
    "include": ["src"],
    "exclude": ["node_modules", ".vscode-test"]
}
