{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "scopeName": "source.rules",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#references" },
        { "include": "#functions" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#keys" },
        { "include": "#unquoted" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "begin": "/\\*",
                    "end": "\\*/",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.comment" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.comment" }
                    },
                    "name": "comment.block"
                },
                {
                    "begin": "//",
                    "end": "$",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.comment" }
                    },
                    "name": "comment.line.double-slash"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double",
                    "begin": "@?\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape",
                            "match": "\\\\."
                        },
                        {
                            "comment": "A reference target quoted as a string — mod actions write AddTo = \"<…rules>/Path\" and db2vol(\"&…\"). Only sigil-led content, so plain quoted text (a localization key) stays a string.",
                            "name": "entity.name.tag",
                            "match": "(<[^>\\n\"]*\\.(?i:rules|txt)[^>\\n\"]*>(?:/[\\w.^~<>-]*)*|&[\\w./^~<>-]*|\\^/[\\w./^~<>-]*|~/[\\w./^~<>-]*)"
                        }
                    ]
                },
                {
                    "comment": "Asset paths (may start with ./ or ../) end in a known extension — a string, not a reference.",
                    "name": "string.unquoted.asset",
                    "match": "(?<![\\w])[\\w./-]*\\.(?i:png|jpg|jpeg|dds|tga|bmp|wav|ogg|mp3|shader|ttf|otf|fnt)(?![\\w])"
                }
            ]
        },
        "references": {
            "patterns": [
                {
                    "comment": "A value is a reference only when it starts with a sigil: <…rules>, &, ^/, ~/, ./, ../, or /Name. A bare leading / followed by a digit stays division (blocked by the digit and the no-word-before guard).",
                    "name": "entity.name.tag",
                    "match": "(?<![\\w.])(<[^>\\n]*\\.(?i:rules|txt)[^>\\n]*>(?:/[\\w.^~<>-]*)*|&[\\w./^~<>-]*|\\^/[\\w./^~<>-]*|~/?[\\w./^~<>-]*|\\.\\.?/[\\w./^~<>-]*|/[A-Za-z_][\\w./^~<>-]*)"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "support.function",
                    "match": "(?<![\\w])[a-zA-Z_][a-zA-Z0-9_]* ?(?=\\()"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric",
                    "match": "(?<![\\w.])-?(?:[Ii]nfinity|(?:\\d+\\.?\\d*|\\.\\d+)(?:[eE][+-]?\\d+)?%?)"
                }
            ]
        },
        "booleans": {
            "patterns": [
                {
                    "name": "constant.language",
                    "match": "(?<![\\w])(?:true|false)(?![\\w])"
                }
            ]
        },
        "keys": {
            "patterns": [
                {
                    "comment": "A field / group / list name before = : { [. Dotted names (cosmoteer.fire) are keys too.",
                    "name": "variable.name",
                    "match": "(?<![\\w])[a-zA-Z_][a-zA-Z0-9_.]*(?=[ \\t]*[:={\\[])"
                },
                {
                    "comment": "A bare group/list header alone on its line (optionally trailed by a comment).",
                    "name": "variable.name",
                    "match": "^[\\t ]*[a-zA-Z_][a-zA-Z0-9_.]*(?=[\\t ]*(?://|$))"
                }
            ]
        },
        "unquoted": {
            "patterns": [
                {
                    "name": "string.unquoted",
                    "match": "[a-zA-Z_][a-zA-Z0-9_.]*"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator",
                    "match": "[-+*/^!%]"
                },
                {
                    "name": "punctuation.paren.open",
                    "match": "\\("
                },
                {
                    "name": "punctuation.paren.close",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.section.brackets",
                    "match": "[\\[\\]{}]"
                },
                {
                    "name": "punctuation.separator.comma",
                    "match": ","
                },
                {
                    "name": "keyword.operator.assignment",
                    "match": "[:=]"
                }
            ]
        }
    }
}
