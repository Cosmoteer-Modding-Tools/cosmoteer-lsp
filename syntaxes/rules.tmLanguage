<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>name</key>
    <string>rules</string>
    <key>scopeName</key>
    <string>source.rules</string>
    <key>fileTypes</key>
    <array>
      <string>rules</string>
    </array>
    <key>patterns</key>
    <array>
      <dict>
        <key>include</key>
        <string>#comments</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#strings</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#references</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#functions</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#numbers</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#booleans</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#keys</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#unquoted</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#operators</string>
      </dict>
    </array>
    <key>repository</key>
    <dict>
      <key>comments</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>begin</key>
            <string>/\*</string>
            <key>end</key>
            <string>\*/</string>
            <key>beginCaptures</key>
            <dict>
              <key>0</key>
              <dict>
                <key>name</key>
                <string>punctuation.definition.comment</string>
              </dict>
            </dict>
            <key>endCaptures</key>
            <dict>
              <key>0</key>
              <dict>
                <key>name</key>
                <string>punctuation.definition.comment</string>
              </dict>
            </dict>
            <key>name</key>
            <string>comment.block</string>
          </dict>
          <dict>
            <key>begin</key>
            <string>//</string>
            <key>end</key>
            <string>$</string>
            <key>beginCaptures</key>
            <dict>
              <key>0</key>
              <dict>
                <key>name</key>
                <string>punctuation.definition.comment</string>
              </dict>
            </dict>
            <key>name</key>
            <string>comment.line.double-slash</string>
          </dict>
        </array>
      </dict>
      <key>strings</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>name</key>
            <string>string.quoted.double</string>
            <key>begin</key>
            <string>@?"</string>
            <key>end</key>
            <string>"</string>
            <key>patterns</key>
            <array>
              <dict>
                <key>name</key>
                <string>constant.character.escape</string>
                <key>match</key>
                <string>\\.</string>
              </dict>
              <dict>
                <key>comment</key>
                <string>A reference target quoted as a string — mod actions write AddTo = "&lt;…rules&gt;/Path" and db2vol("&amp;…"). Only sigil-led content, so plain quoted text (a localization key) stays a string.</string>
                <key>name</key>
                <string>entity.name.tag</string>
                <key>match</key>
                <string>(&lt;[^&gt;\n"]*\.(?i:rules|txt)[^&gt;\n"]*&gt;(?:/[\w.^~&lt;&gt;-]*)*|&amp;[\w./^~&lt;&gt;-]*|\^/[\w./^~&lt;&gt;-]*|~/[\w./^~&lt;&gt;-]*)</string>
              </dict>
            </array>
          </dict>
          <dict>
            <key>comment</key>
            <string>Asset paths (may start with ./ or ../) end in a known extension — a string, not a reference.</string>
            <key>name</key>
            <string>string.unquoted.asset</string>
            <key>match</key>
            <string>(?&lt;![\w])[\w./-]*\.(?i:png|jpg|jpeg|dds|tga|bmp|wav|ogg|mp3|shader|ttf|otf|fnt)(?![\w])</string>
          </dict>
        </array>
      </dict>
      <key>references</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>comment</key>
            <string>A value is a reference only when it starts with a sigil: &lt;…rules&gt;, &amp;, ^/, ~/, ./, ../, or /Name. A bare leading / followed by a digit stays division (blocked by the digit and the no-word-before guard).</string>
            <key>name</key>
            <string>entity.name.tag</string>
            <key>match</key>
            <string>(?&lt;![\w.])(&lt;[^&gt;\n]*\.(?i:rules|txt)[^&gt;\n]*&gt;(?:/[\w.^~&lt;&gt;-]*)*|&amp;[\w./^~&lt;&gt;-]*|\^/[\w./^~&lt;&gt;-]*|~/?[\w./^~&lt;&gt;-]*|\.\.?/[\w./^~&lt;&gt;-]*|/[A-Za-z_][\w./^~&lt;&gt;-]*)</string>
          </dict>
        </array>
      </dict>
      <key>functions</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>name</key>
            <string>support.function</string>
            <key>match</key>
            <string>(?&lt;![\w])[a-zA-Z_][a-zA-Z0-9_]* ?(?=\()</string>
          </dict>
        </array>
      </dict>
      <key>numbers</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>name</key>
            <string>constant.numeric</string>
            <key>match</key>
            <string>(?&lt;![\w.])-?(?:[Ii]nfinity|(?:\d+\.?\d*|\.\d+)(?:[eE][+-]?\d+)?%?)</string>
          </dict>
        </array>
      </dict>
      <key>booleans</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>name</key>
            <string>constant.language</string>
            <key>match</key>
            <string>(?&lt;![\w])(?:true|false)(?![\w])</string>
          </dict>
        </array>
      </dict>
      <key>keys</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>comment</key>
            <string>A field / group / list name before = : { [. Dotted names (cosmoteer.fire) are keys too.</string>
            <key>name</key>
            <string>variable.name</string>
            <key>match</key>
            <string>(?&lt;![\w])[a-zA-Z_][a-zA-Z0-9_.]*(?=[ \t]*[:={\[])</string>
          </dict>
          <dict>
            <key>comment</key>
            <string>A bare group/list header alone on its line (optionally trailed by a comment).</string>
            <key>name</key>
            <string>variable.name</string>
            <key>match</key>
            <string>^[\t ]*[a-zA-Z_][a-zA-Z0-9_.]*(?=[\t ]*(?://|$))</string>
          </dict>
        </array>
      </dict>
      <key>unquoted</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>name</key>
            <string>string.unquoted</string>
            <key>match</key>
            <string>[a-zA-Z_][a-zA-Z0-9_.]*</string>
          </dict>
        </array>
      </dict>
      <key>operators</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>name</key>
            <string>keyword.operator</string>
            <key>match</key>
            <string>[-+*/^!%]</string>
          </dict>
          <dict>
            <key>name</key>
            <string>punctuation.paren.open</string>
            <key>match</key>
            <string>\(</string>
          </dict>
          <dict>
            <key>name</key>
            <string>punctuation.paren.close</string>
            <key>match</key>
            <string>\)</string>
          </dict>
          <dict>
            <key>name</key>
            <string>punctuation.section.brackets</string>
            <key>match</key>
            <string>[\[\]{}]</string>
          </dict>
          <dict>
            <key>name</key>
            <string>punctuation.separator.comma</string>
            <key>match</key>
            <string>,</string>
          </dict>
          <dict>
            <key>name</key>
            <string>keyword.operator.assignment</string>
            <key>match</key>
            <string>[:=]</string>
          </dict>
        </array>
      </dict>
    </dict>
  </dict>
</plist>
